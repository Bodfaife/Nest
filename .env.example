# Local Development Environment Variables
# Copy this file to .env.local and fill in your actual credentials

# EmailJS Configuration (deprecated – not required)
# These were used previously for sending OTP/recovery emails. The current
# application no longer sends any outbound email, so you can safely ignore or
# delete these entries.
#REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_from_emailjs_here
#REACT_APP_EMAILJS_SERVICE_ID=service_xxxxx
#REACT_APP_EMAILJS_TEMPLATE_ID=template_xxxxx
